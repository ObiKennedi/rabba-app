{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/page.css",
      "static/chunks/app/page.js"
    ],
    "/(auth)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(auth)/layout.css",
      "static/chunks/app/(auth)/layout.js"
    ],
    "/(auth)/sign-in/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(auth)/sign-in/page.css",
      "static/chunks/app/(auth)/sign-in/page.js"
    ],
    "/api/auth/[...nextauth]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/auth/[...nextauth]/route.js"
    ],
    "/(root)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(root)/layout.css",
      "static/chunks/app/(root)/layout.js"
    ],
    "/(root)/(dashboard)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(root)/(dashboard)/layout.css",
      "static/chunks/app/(root)/(dashboard)/layout.js"
    ],
    "/(root)/(dashboard)/home/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(root)/(dashboard)/home/page.js"
    ]
  }
}